{
  "name": "kha-dock-homes-construction-llc-website",
  "version": "1.0.0",
  "description": "Kha Dock & Home Construction LLC Website",
  "main": "index.html",
  "scripts": {
    "build": "tailwindcss -i ./css/tailwind.css -o ./css/tailwind-output.css --minify",
    "dev": "tailwindcss -i ./css/tailwind.css -o ./css/tailwind-output.css --watch",
    "start": "npx serve .",
    "deploy": "npm run build && firebase deploy --only hosting:khahome --project ivs-tech",
    "deploy:force": "npm run build && firebase deploy --only hosting:khahome --force --project ivs-tech",
    "fetch-facebook": "node scripts/fetch-facebook-posts.js",
    "schedule-facebook": "node scripts/schedule-facebook-fetch.js"
  },
  "keywords": [
    "construction",
    "home-renovation",
    "dock-building",
    "florida"
  ],
  "author": "Kha Dock & Home Construction LLC",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "tailwindcss": "^3.4.0"
  },
  "dependencies": {
    "playwright": "^1.56.1",
    "serve": "^14.2.1",
    "firebase-admin": "^12.0.0",
    "node-cron": "^3.0.3",
    "dotenv": "^16.4.5"
  }
}
